# NorthStar Sandbox Dashboard public configuration lives in dashboard/sandbox/dashboard/config.js.
# Do not put secrets in dashboard/config.js or any frontend file.

# Vercel Sandbox API project only
NORTHSTAR_ENV=tiktok_sandbox
TIKTOK_CLIENT_KEY_SANDBOX=your_sandbox_client_key
TIKTOK_CLIENT_SECRET_SANDBOX=your_sandbox_client_secret
TIKTOK_REDIRECT_URI_SANDBOX=https://sandbox-api.northstar-creator.com/auth/tiktok/callback
TIKTOK_SCOPES=user.info.basic,user.info.stats,video.list

TIKTOK_SANDBOX_FRONTEND_URL=https://sandbox-app.northstar-creator.com
API_ORIGIN=https://sandbox-api.northstar-creator.com
SESSION_COOKIE_NAME=northstar_sandbox_session
TOKEN_STORE_SECRET_SANDBOX=replace_with_a_long_random_secret_at_least_32_characters
TOKEN_STORE_PREFIX_SANDBOX=northstar:sandbox

# Upstash Redis through the Vercel Marketplace.
# These are temporary encrypted session/token storage only, not a NorthStar product database.
UPSTASH_REDIS_REST_URL_SANDBOX=https://your-upstash-rest-url
UPSTASH_REDIS_REST_TOKEN_SANDBOX=your-upstash-rest-token
