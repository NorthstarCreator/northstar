# NorthStar Dashboard public configuration lives in dashboard/config.js.
# Do not put secrets in dashboard/config.js or any frontend file.

# Vercel API project only
TIKTOK_CLIENT_KEY=your_sandbox_client_key
TIKTOK_CLIENT_SECRET=your_sandbox_client_secret
TIKTOK_REDIRECT_URI=https://api.northstar-creator.com/auth/tiktok/callback
TIKTOK_SCOPES=user.info.basic,user.info.stats,video.list

APP_ORIGIN=https://app.northstar-creator.com
API_ORIGIN=https://api.northstar-creator.com
SESSION_COOKIE_NAME=northstar_session
TOKEN_STORE_SECRET=replace_with_a_long_random_secret_at_least_32_characters

# Upstash Redis through the Vercel Marketplace
UPSTASH_REDIS_REST_URL=https://your-upstash-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
