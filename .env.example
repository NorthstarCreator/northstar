# NorthStar environment variable reference.
# Copy these names into the correct Vercel project/environment and provide the
# values there. Do not commit real values, secrets, tokens, or database URLs.

# Runtime/environment guard.
NORTHSTAR_ENV=
NORTHSTAR_DATABASE_ENV=

# Disabled-by-default, read-only database health endpoint.
# Use a separate random bearer token of at least 32 characters.
NORTHSTAR_DATABASE_HEALTH_ENABLED=
NORTHSTAR_DATABASE_HEALTH_TOKEN=

# Disabled-by-default durable TikTok Display API persistence.
# Enable only in the isolated sandbox API after its database marker is verified.
NORTHSTAR_PERSIST_SYNC_ENABLED=
TIKTOK_VIDEO_SYNC_MAX_PAGES=

# TikTok Sandbox OAuth.
TIKTOK_CLIENT_KEY_SANDBOX=
TIKTOK_CLIENT_SECRET_SANDBOX=
TIKTOK_REDIRECT_URI_SANDBOX=
TIKTOK_SCOPES=

# Sandbox dashboard/API origins.
TIKTOK_SANDBOX_FRONTEND_URL=
TIKTOK_SANDBOX_REDIRECT_ORIGIN=
TIKTOK_SANDBOX_FRONTEND_URLS=
API_ORIGIN=

# Secure session cookie name.
SESSION_COOKIE_NAME=

# Upstash Redis remains temporary encrypted session/OAuth/token storage only.
TOKEN_STORE_SECRET_SANDBOX=
TOKEN_STORE_PREFIX_SANDBOX=
UPSTASH_REDIS_REST_URL_SANDBOX=
UPSTASH_REDIS_REST_TOKEN_SANDBOX=

# Neon Postgres data foundation.
# Use only server-side API environments. Never expose these in dashboard config.
DATABASE_URL_SANDBOX=
POSTGRES_URL_SANDBOX=
NEON_DATABASE_URL_SANDBOX=
DATABASE_URL=
POSTGRES_URL=
NEON_DATABASE_URL=
DATABASE_URL_DEVELOPMENT=
POSTGRES_URL_DEVELOPMENT=
